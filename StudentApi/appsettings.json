  },
  "Jwt": { 
    "Key": "rtoiete4564rtfdoodsjfs4kwrewkere324",
    "Issuer": "https://studenttest.com",
    "audience": "https://studenttest.com",
    "MobileAppExpiryMinutes": 86400
